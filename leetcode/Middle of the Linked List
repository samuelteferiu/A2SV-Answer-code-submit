# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def middleNode(self, head: Optional[ListNode]) -> Optional[ListNode]:
        once=head
        twice=head
        while twice and twice.next:
            twice=twice.next.next
            once=once.next
        return once
