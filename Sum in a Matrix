class Solution:
    def matrixSum(self, nums: List[List[int]]) -> int:
        score = 0
        while nums:
            maxs = 0
            for i in nums:
                x = max(i)
                maxs = max(maxs, x)
                i.remove(x)
            nums = [x for x in nums if x]
            score += maxs
        return score
