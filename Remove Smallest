t = int(input())
for _ in range(t):
    n = int(input())
    a = sorted(set(map(int, input().split())))  
    prev = a[0]
    dif = []
    for i in range(1, len(a)):
        if abs(a[i] - prev) == 1: 
            dif.append(prev)
        prev = a[i]
    if len(dif) == len(a) - 1:
        print("YES")
    else:
        print("NO")
